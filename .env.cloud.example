# PRODEMUNDIAL 2026 — Supabase cloud (Prode uf)
# Copiar a .env.cloud y completar claves desde:
# https://supabase.com/dashboard/project/irklqwsnehlfcgehvscm/settings/api

SUPABASE_PROJECT_REF=irklqwsnehlfcgehvscm

# --- Frontend (Vercel) ---
VITE_SUPABASE_URL=https://irklqwsnehlfcgehvscm.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_USE_FOOTBALL_API=true
VITE_PUBLIC_DEMO=false
VITE_API_BASE_URL=

# --- Backend + Worker (Oracle) ---
SUPABASE_URL=https://irklqwsnehlfcgehvscm.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
NODE_ENV=production
CORS_ORIGIN=https://prodemundialprode.vercel.app
WORKER_HOST=oracle-cloud
FOOTBALL_DATA_API_KEY=
API_FOOTBALL_KEY=
API_FOOTBALL_WORLD_CUP_LEAGUE_ID=1
API_FOOTBALL_WORLD_CUP_SEASON=2026
# --- Cuenta admin maestra (npm run admin:create-master) ---
# MASTER_ADMIN_EMAIL=maestro@prodemundial.prode
# MASTER_ADMIN_DNI=47000001
# MASTER_ADMIN_LEGAJO=MAESTRO
# MASTER_ADMIN_NAME=Admin Maestro
# Límite por corrida — evita horas de API externa
ENRICH_PLAYERS_LIMIT=25
# Modo rápido: solo API-Football/Sportmonks (sin TheSportsDB/Wikimedia)
PLAYER_ENRICH_FAST=1
PLAYER_ENRICH_DELAY_MS=200
PLAYER_ENRICH_PROVIDER_TIMEOUT_MS=15000
