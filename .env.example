# =============================================================================
# PRODEMUNDIAL 2026 — Variables de entorno
# Copiar a .env.local (dev) o configurar en Vercel / GitHub Secrets
# =============================================================================

# --- FRONTEND (Vercel — producción $0 Supabase-only) ---
VITE_SUPABASE_URL=https://TU_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_USE_FOOTBALL_API=false
VITE_PUBLIC_DEMO=false
# NO configurar VITE_API_BASE_URL en producción $0

# --- Solo desarrollo local con Express (opcional) ---
# VITE_USE_FOOTBALL_API=true
# VITE_API_BASE_URL=http://127.0.0.1:3001
# VITE_API_PROXY_TARGET=http://127.0.0.1:3001

# --- SYNC (GitHub Actions Secrets — NUNCA en Vercel) ---
SUPABASE_URL=https://TU_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
FOOTBALL_DATA_API_KEY=
# Alternativa si no usás football-data.org:
# API_FOOTBALL_KEY=

# --- Opcional sync ---
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_WORLD_CUP_CODE=WC
FOOTBALL_DATA_SEASON=2026
API_FOOTBALL_WORLD_CUP_LEAGUE_ID=1
API_FOOTBALL_WORLD_CUP_SEASON=2026
SKIP_PLAYER_ENRICH=1

# --- Admin dev local ---
VITE_DEV_ADMIN=false

# =============================================================================
# DESARROLLO LOCAL (opcional — no usar en producción)
# =============================================================================
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_URL=http://127.0.0.1:54321
# npm run services:up  → supabase local
# npm run sync:cloud:all  → requiere .env.cloud con credenciales cloud
