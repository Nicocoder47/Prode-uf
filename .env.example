# =============================================================================
# PRODEMUNDIAL 2026 — Variables de entorno
# Copiar a .env (local) o configurar en Vercel / Oracle Cloud
# =============================================================================

# --- FRONTEND (Vercel) ---
VITE_SUPABASE_URL=https://TU_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=
# URL pública del backend Oracle (sin barra final)
VITE_API_BASE_URL=https://api.tudominio.com
VITE_USE_FOOTBALL_API=true
# Solo desarrollo: proxy Vite → Express local
# VITE_API_PROXY_TARGET=http://127.0.0.1:3001

# --- BACKEND + WORKER (Oracle Cloud) ---
SUPABASE_URL=https://TU_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
NODE_ENV=production
API_PORT=3001
API_HOST=0.0.0.0
# Origen del frontend Vercel (CORS)
CORS_ORIGIN=https://tu-app.vercel.app
WORKER_HOST=oracle-vm-1

# --- REDIS Upstash Free (opcional — si falla, sync sigue con Supabase) ---
# REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:6379

# --- APIs deportivas (servidor únicamente, nunca en Vercel) ---
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_WORLD_CUP_CODE=WC
FOOTBALL_DATA_SEASON=2026
API_FOOTBALL_KEY=
API_FOOTBALL_WORLD_CUP_LEAGUE_ID=1
API_FOOTBALL_WORLD_CUP_SEASON=2026
SPORTMONKS_API_TOKEN=
TRANSFERMARKT_API_BASE=

# --- Admin dev local ---
VITE_DEV_ADMIN=false

# --- Enriquecimiento jugadores ---
PLAYER_ENRICH_BATCH_SIZE=25
PLAYER_ENRICH_DELAY_MS=800
PLAYER_ENRICH_MAX_PER_RUN=200
PLAYER_ENRICH_MIN_SCORE=75
THESPORTSDB_API_KEY=
PHOTO_SYNC_LIMIT=40
ENRICH_PLAYERS_LIMIT=80
ENRICH_PLAYERS_DELAY_MS=650

# =============================================================================
# DESARROLLO LOCAL (opcional — no usar en producción)
# =============================================================================
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_URL=http://127.0.0.1:54321
# REDIS_URL=redis://127.0.0.1:6379
# npm run services:up  → docker compose redis + supabase local
